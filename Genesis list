--------------------------------------------------------------------------------
-- LOADING SCREEN SNOWFLAKES
--------------------------------------------------------------------------------
local loadingSnowflakes = {}
local LOADING_SNOW_COUNT = 60

for i = 1, LOADING_SNOW_COUNT do
    local snow = Instance.new("Frame")

    local size = math.random(2, 5)
    snow.Size = UDim2.new(0, size, 0, size)
    snow.Position = UDim2.new(math.random(), 0, math.random() * -0.5, 0)
    snow.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    snow.BackgroundTransparency = 0.6 + math.random() * 0.3
    snow.BorderSizePixel = 0
    snow.ZIndex = 1
    snow.Parent = loadingFrame

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(1, 0)
    corner.Parent = snow

    snow:SetAttribute("SpeedY", 0.0006 + math.random() * 0.0012)
    snow:SetAttribute("SpeedX", (math.random() - 0.5) * 0.0003)
    snow:SetAttribute("SwayOffset", math.random() * 100)

    table.insert(loadingSnowflakes, snow)
end

--------------------------------------------------------------------------------
-- LOADING SNOW ANIMATION
--------------------------------------------------------------------------------
local loadingSnowTime = 0
local loadingSnowRunning = true

local loadingSnowConnection = RunService.RenderStepped:Connect(function(dt)
    if not loadingSnowRunning then return end

    loadingSnowTime += dt

    for _, snow in pairs(loadingSnowflakes) do
        local pos = snow.Position

        local speedY = snow:GetAttribute("SpeedY")
        local speedX = snow:GetAttribute("SpeedX")
        local swayOffset = snow:GetAttribute("SwayOffset")

        local sway = math.sin(loadingSnowTime * 1.5 + swayOffset) * 0.0004

        local newY = pos.Y.Scale + speedY
        local newX = pos.X.Scale + speedX + sway

        if newY > 1.1 then
            newY = -0.1
            newX = math.random()
        end

        if newX < -0.1 then newX = 1.1 end
        if newX > 1.1 then newX = -0.1 end

        snow.Position = UDim2.new(newX, 0, newY, 0)
    end
end)

