-- Detect mobile: touch enabled and no mouse means phone/tablet
local isMobile = UserInputService.TouchEnabled and not UserInputService.MouseEnabled

-- UIScale parented to screenGui so it scales everything inside it uniformly
local uiScaleInstance = Instance.new("UIScale")
uiScaleInstance.Scale = 1
uiScaleInstance.Parent = screenGui

local function updateUIScale()
    if isMobile then
        local vp = workspace.CurrentCamera.ViewportSize
        -- Fit the 650x700 frame within 95% of the screen on both axes
        local scaleX = (vp.X * 0.95) / 650
        local scaleY = (vp.Y * 0.95) / 700
        uiScaleInstance.Scale = math.min(scaleX, scaleY)
    else
        uiScaleInstance.Scale = 1
    end
end

updateUIScale()

-- Recompute on screen resize / orientation change
workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(function()
    updateUIScale()
end)

